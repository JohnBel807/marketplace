{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://api.velezyricaurte.info/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://www.velezyricaurte.info" }
      ]
    }
  ]
}
